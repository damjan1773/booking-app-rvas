<!DOCTYPE html>
<html lang="sr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookingApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BookingApp.styles.css" asp-append-version="true" />
</head>

<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-booking shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-semibold" asp-controller="Accommodation" asp-action="Index">
                    <i class="bi bi-house-heart-fill me-1"></i>BookingApp
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Meni">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Accommodation" asp-action="Index">
                                <i class="bi bi-building me-1"></i>SmeÜtaji
                            </a>
                        </li>

                        @{
                            var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
                        }

                        @if (userRole == "Owner")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Accommodation" asp-action="Create">
                                    <i class="bi bi-plus-circle me-1"></i>Dodaj smeÜtaj
                                </a>
                            </li>
                        }

                        @if (userRole == "Guest")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Reservation" asp-action="MyReservations">
                                    <i class="bi bi-calendar-check me-1"></i>Moje rezervacije
                                </a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav align-items-lg-center gap-lg-2">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="navbar-text user-badge px-3 py-1 rounded-pill">
                                    <i class="bi bi-person-circle me-1"></i>
                                    @User.Identity.Name
                                    <span class="badge bg-light text-booking ms-1">@userRole</span>
                                </span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-outline-light btn-sm">
                                        <i class="bi bi-box-arrow-right me-1"></i>Odjavi se
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">Prijava</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-light btn-sm text-booking fw-semibold ms-lg-1"
                                   asp-controller="Account" asp-action="Register">Registracija</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="flex-grow-1 py-4">
        @RenderBody()
    </main>

    <footer class="footer-booking py-3 mt-auto">
        <div class="container text-center small">
            &copy; 2026 BookingApp Ś RVAS projekat
            <span class="mx-2">|</span>
            Tim: Damjan, Milun, Lazar, Marko
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
