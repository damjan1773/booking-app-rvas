@{
    ViewData["Title"] = "Pocetna";
}

<div class="container">
    <div class="hero-home text-center">
        <h1 class="display-5 fw-bold mb-3">
            <i class="bi bi-house-heart me-2"></i>Dobrodošli u BookingApp
        </h1>
        <p class="lead mb-4">
            Pronadi i rezerviši savršen smeštaj — brzo, jednostavno i sigurno.
        </p>
        <div class="d-flex flex-wrap justify-content-center gap-2">
            <a asp-controller="Accommodation" asp-action="Index" class="btn btn-light btn-lg text-booking fw-semibold">
                <i class="bi bi-search me-1"></i>Pregledaj smeštaje
            </a>
            @if (User.Identity?.IsAuthenticated != true)
            {
                <a asp-controller="Account" asp-action="Register" class="btn btn-outline-light btn-lg">
                    Registruj se
                </a>
            }
        </div>
    </div>

    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 p-4">
                <i class="bi bi-building fs-1 text-booking mb-3"></i>
                <h5>Širok izbor</h5>
                <p class="text-muted mb-0">Pregledaj smeštaje širom Srbije sa filterima po lokaciji i ceni.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 p-4">
                <i class="bi bi-calendar-check fs-1 text-booking mb-3"></i>
                <h5>Brza rezervacija</h5>
                <p class="text-muted mb-0">Rezerviši termin u nekoliko klikova — provera dostupnosti u realnom vremenu.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 p-4">
                <i class="bi bi-shield-check fs-1 text-booking mb-3"></i>
                <h5>Sigurno</h5>
                <p class="text-muted mb-0">Registracija kao gost ili vlasnik smeštaja sa zašticenim nalogom.</p>
            </div>
        </div>
    </div>
</div>
