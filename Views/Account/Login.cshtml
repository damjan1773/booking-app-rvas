@model BookingApp.Models.LoginViewModel
@{
    ViewData["Title"] = "Prijava";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="auth-card">
                <h2 class="mb-4 text-center">
                    <i class="bi bi-box-arrow-in-right text-booking me-2"></i>Prijava
                </h2>
                <form asp-action="Login" method="post" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" type="email" required placeholder="email@primer.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Lozinka</label>
                        <input asp-for="Password" class="form-control" type="password" required minlength="6" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Prijavi se
                    </button>
                </form>
                <p class="mt-3 text-center mb-0">
                    Nemaš nalog? <a asp-action="Register" class="fw-semibold">Registruj se</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
