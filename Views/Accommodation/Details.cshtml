@model Accommodation

<div class="container mt-4">
    <div class="card shadow">
        @if (Model.ImagePaths.Any()) {
            <img src="@Model.ImagePaths[0]" class="card-img-top" style="height:350px; object-fit:cover;">
        }
        <div class="card-body">
            <h2 class="card-title">@Model.Name</h2>
            <p class="text-muted">📍 @Model.Location</p>
            <hr />
            <p>@Model.Description</p>
            <h4 class="text-success">💰 @Model.PricePerNight €/noć</h4>

            @if (Model.Amenities.Any()) {
                <hr />
                <h5>Pogodnosti:</h5>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var amenity in Model.Amenities) {
                        <span class="badge bg-secondary fs-6">@amenity</span>
                    }
                </div>
            }

            @if (Model.ImagePaths.Count > 1) {
                <hr />
                <h5>Galerija:</h5>
                <div class="row">
                    @foreach (var img in Model.ImagePaths.Skip(1)) {
                        <div class="col-md-4 mb-3">
                            <img src="@img" class="img-fluid rounded shadow-sm">
                        </div>
                    }
                </div>
            }

            @{
                var upcoming = (List<Reservation>?)ViewBag.UpcomingReservations ?? new List<Reservation>();
            }

            <hr />
            <h5>Zauzeti termini</h5>
            @if (!upcoming.Any())
            {
                <p class="text-muted">Smeštaj je trenutno dostupan u svim terminima.</p>
            }
            else
            {
                <ul class="list-group mb-3">
                    @foreach (var r in upcoming)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <span>📅 @r.CheckIn.ToString("dd.MM.yyyy") — @r.CheckOut.ToString("dd.MM.yyyy")</span>
                            <span class="badge bg-danger">Zauzeto</span>
                        </li>
                    }
                </ul>
            }

            <hr />
            <div class="d-flex gap-2">
                <a href="/Accommodation/Index" class="btn btn-secondary">Nazad</a>
                @if (User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value == "Guest") {
                    <a href="/Reservation/Create?accommodationId=@Model.Id" class="btn btn-success">Rezerviši</a>
                }
                @if (User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value == "Owner") {
                    <a href="/Accommodation/Edit/@Model.Id" class="btn btn-warning">Izmeni</a>
                    <a href="/Accommodation/Delete/@Model.Id" class="btn btn-danger">Obriši</a>
                }
            </div>
        </div>
    </div>
</div>