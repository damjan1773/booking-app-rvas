@model Accommodation
@{
    ViewData["Title"] = "Dodaj smeštaj";
}

<div class="container">
    <div class="page-header">
        <h2><i class="bi bi-plus-circle text-booking me-2"></i>Dodaj smeštaj</h2>
        <p>Popuni podatke o novom smeštaju.</p>
    </div>

    <div class="form-card">
        <form method="post" enctype="multipart/form-data" novalidate>
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Naziv</label>
                <input asp-for="Name" class="form-control" required minlength="2" maxlength="100"
                       placeholder="npr. Vila Sunce" />
            </div>
            <div class="mb-3">
                <label asp-for="Location" class="form-label">Lokacija</label>
                <input asp-for="Location" class="form-control" required minlength="2" maxlength="100"
                       placeholder="npr. Zlatibor, Srbija" />
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label">Opis</label>
                <textarea asp-for="Description" class="form-control" rows="4" required minlength="10"
                          placeholder="Opišite smeštaj..."></textarea>
            </div>
            <div class="mb-3">
                <label asp-for="PricePerNight" class="form-label">Cena po noći (€)</label>
                <input asp-for="PricePerNight" type="number" class="form-control" required min="1" max="10000" step="0.01" />
            </div>
            <div class="mb-3">
                <label class="form-label">Pogodnosti</label>
                <input type="text" name="amenitiesInput" class="form-control"
                       placeholder="WiFi, Parking, Klima (odvojeno zarezom)" />
                <div class="form-text">Unesi pogodnosti odvojene zarezom.</div>
            </div>
            <div class="mb-4">
                <label class="form-label">Slika</label>
                <input type="file" name="image" class="form-control" accept="image/*" />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Dodaj
                </button>
                <a asp-action="Index" class="btn btn-secondary">Nazad</a>
            </div>
        </form>
    </div>
</div>
