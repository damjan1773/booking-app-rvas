@model Reservation
@{
    ViewData["Title"] = "Rezervacija smeštaja";
    var accommodation = (Accommodation)ViewBag.Accommodation;
}

<div class="container mt-4">
    <h2>Rezervacija: @accommodation.Name</h2>
    <p class="text-muted">@accommodation.Location — @accommodation.PricePerNight.ToString("0.00") € po noći</p>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@err.ErrorMessage</div>
            }
        </div>
    }

    <form asp-action="Create" method="post" class="mt-3">
        <input type="hidden" asp-for="AccommodationId" />

        <div class="mb-3">
            <label class="form-label">Datum dolaska</label>
            <input name="CheckIn" type="date" class="form-control" required
                   value="@(Model.CheckIn > DateTime.MinValue ? Model.CheckIn.ToString("yyyy-MM-dd") : "")" />
        </div>

        <div class="mb-3">
            <label class="form-label">Datum odlaska</label>
            <input name="CheckOut" type="date" class="form-control" required
                   value="@(Model.CheckOut > DateTime.MinValue ? Model.CheckOut.ToString("yyyy-MM-dd") : "")" />
        </div>

        <button type="submit" class="btn btn-primary">Rezerviši</button>
        <a asp-controller="Accommodation" asp-action="Details" asp-route-id="@accommodation.Id" class="btn btn-secondary">Otkaži</a>
    </form>
</div>