@model List<Reservation>
@{
    ViewData["Title"] = "Rezervacije smeštaja";
    var accommodation = (Accommodation)ViewBag.Accommodation;
}

<div class="container">
    <div class="page-header">
        <h2><i class="bi bi-people text-booking me-2"></i>Rezervacije</h2>
        <p>@accommodation.Name — <i class="bi bi-geo-alt"></i> @accommodation.Location</p>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <h4>Nema rezervacija</h4>
            <p class="text-muted">Ovaj smeštaj još nema rezervacija.</p>
        </div>
    }
    else
    {
        <div class="table-responsive table-booking">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Gost</th>
                        <th>Dolazak</th>
                        <th>Odlazak</th>
                        <th>Noćenja</th>
                        <th>Ukupno</th>
                        <th>Rezervisano</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        var nights = (r.CheckOut - r.CheckIn).Days;
                        <tr>
                            <td class="fw-semibold">@r.GuestName</td>
                            <td>@r.CheckIn.ToString("dd.MM.yyyy")</td>
                            <td>@r.CheckOut.ToString("dd.MM.yyyy")</td>
                            <td>@nights</td>
                            <td class="text-success fw-semibold">@r.TotalPrice.ToString("0.00") €</td>
                            <td class="text-muted small">@r.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <a asp-controller="Accommodation" asp-action="Details" asp-route-id="@accommodation.Id"
       class="btn btn-secondary mt-4">
        <i class="bi bi-arrow-left me-1"></i>Nazad na smeštaj
    </a>
</div>
